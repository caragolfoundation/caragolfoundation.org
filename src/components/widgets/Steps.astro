---
import { Icon } from "astro-icon";
import { Picture } from "@astrojs/image/components";
import config from "~/config/config.json";
---

<section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl">
  <div class="grid gap-6 row-gap-10 md:grid-cols-2">
    <div class="md:pb-6 md:pr-16">
      <h2 class="mb-8 text-3xl lg:text-4xl font-bold font-heading">
        {config.stepsHeader}
      </h2>
      <div class="flex">
        <div class="flex flex-col items-center mr-4">
          <div>
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border-primary-600 border-2"
            >
              <Icon
                name={config.steps[0].icon}
                class="w-6 h-6 text-primary-600 dark:text-slate-200"
              />
            </div>
          </div>
          <div class="w-px h-full bg-gray-300 dark:bg-slate-500"></div>
        </div>
        <div class="pt-1 pb-8">
          <p class="mb-2 text-xl font-bold text-gray-900 dark:text-slate-300">
            Step 1
          </p>
          <p class="text-gray-600 dark:text-slate-400">
            {config.steps[0].text}
          </p>
        </div>
      </div>
      <div class="flex">
        <div class="flex flex-col items-center mr-4">
          <div>
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border-primary-600 border-2"
            >
              <Icon
                name={config.steps[1].icon}
                class="w-6 h-6 text-primary-600 dark:text-slate-200"
              />
            </div>
          </div>
          <div class="w-px h-full bg-gray-300 dark:bg-slate-500"></div>
        </div>
        <div class="pt-1 pb-8">
          <p class="mb-2 text-xl font-bold text-gray-900 dark:text-slate-300">
            Step 2
          </p>
          <p class="text-gray-600 dark:text-slate-400">
            {config.steps[1].text}
          </p>
        </div>
      </div>
      <div class="flex">
        <div class="flex flex-col items-center mr-4">
          <div>
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border-primary-600 border-2"
            >
              <Icon
                name={config.steps[2].icon}
                class="w-6 h-6 text-primary-600 dark:text-slate-200"
              />
            </div>
          </div>
          <div class="w-px h-full bg-gray-300 dark:bg-slate-500"></div>
        </div>
        <div class="pt-1 pb-8">
          <p class="mb-2 text-xl font-bold text-gray-900 dark:text-slate-300">
            Step 3
          </p>
          <p class="text-gray-600 dark:text-slate-400">
            {config.steps[2].text}
          </p>
        </div>
      </div>
      <div class="flex">
        <div class="flex flex-col items-center mr-4">
          <div>
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border-primary-600 border-2 bg-primary-600"
            >
              <Icon
                name={config.steps[3].icon}
                class="w-6 h-6 text-white dark:text-slate-200"
              />
            </div>
          </div>
        </div>
        <div class="pt-1">
          <p class="mb-2 text-xl font-bold text-gray-900 dark:text-slate-300">
            {config.steps[3].text}
          </p>
          <p class="text-gray-600 dark:text-slate-400"></p>
        </div>
      </div>
    </div>
    <div class="relative">
      <Picture
        class="inset-0 object-cover object-top w-full rounded-md shadow-lg md:absolute md:h-full bg-gray-400 dark:bg-slate-700"
        src={import("~/assets/images/hands-on-tree.jpg")}
        widths={[400, 768]}
        sizes="(max-width: 768px) 100vw, 432px"
        alt="Hands on Tree"
        aspectRatio="432:768"
      />
    </div>
  </div>
</section>
